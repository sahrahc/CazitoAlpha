/* Position the major areas. Because of reset, all the sizes must add up*/
/* layout **************************************************************/
.header {
    border-style: outset;
    border-color: green;
    border-width:2px;
    height:50px;
    background-color:khaki;
    width:642px;
}
.header > div {
    display:inline;
}
/* the main part, may be contain left and right frames */
.main {
    width: 1024px;
    height: 768px;
    padding: 5px 5px;
    z-index:-1;
    background-image:url('../../../images/window-bg.png');
    background-repeat:no-repeat;
}
.main left-frame {
    width:220px;
    height: 444px;
    padding: 5px 5px 5px 0px;
    float:left;     
}
.main right-frame {
    position:relative;  /* elements within must align top or bottom */
    width: 152px;
    height: 436px;
    border-radius: 3px;
    /* left: 642px; /* = container width */
    float: right;  
}
.log{
    width:1014px;
    height: 80px;
    background-color: white;
    text-align:left;
    color:blue;
    clear: both;
    opacity: 0.6;
    border-radius: 3px;
    padding: 5px 5px;
    margin-bottom: 5px;
    overflow: auto;
}
.footer
{
    width:1014px;
    height: 20px;
    background-color: #9EB8F0;
    text-align: center;
    clear: both;
    opacity: 0.6;
    border-radius: 3px;
    padding: 0px 5px;
}

/* header **************************************************************/
/* ul on the top area is for session information only hence no display */
.hidden {
    display:none;
}

.title {
    float:left; 
    width: 500px; 
    font-size: 1.5em; 
    color: white;
}

