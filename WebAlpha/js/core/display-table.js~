/**
 * Sets up the entire table based on game status
 * @param {GameStatusDto} gameStatusDto
 * @returns {undefined}
 */
function setupTable(gameStatusDto) {
    // active game portion
    O('gameInstanceId').innerHTML = gameStatusDto.gameInstanceId;

    // update everyone's statuses, which should include the blind bets
    resetPlayersCardsDisplay(gameStatusDto.playerStatusDtos);
    setupPlayerStatuses(gameStatusDto.playerStatusDtos);

     if (gameStatusDto.userPlayerHandDto !== null) {
        var playerElement;  
        playerElement = getPlayerPositionTag($.cookies.get('userPlayerId'));
        O(playerElement + 'Card1').innerHTML = gameStatusDto.userPlayerHandDto.pokerCard1Code;
        O(playerElement + 'Card2').innerHTML = gameStatusDto.userPlayerHandDto.pokerCard2Code;
        showPlayerCard(playerElement, 1, gameStatusDto.userPlayerHandDto.pokerCard1Code);
        showPlayerCard(playerElement, 2, gameStatusDto.userPlayerHandDto.pokerCard2Code);
 
        // enable cheating items
        disableInstanceItems(true);
    }
    // check is disabled when a game first starts
    if (gameStatusDto.nextMoveDto !== null) {
        processNextPlayer(gameStatusDto.nextMoveDto, false);
    }
    // dealer designation
    var dealerPlayerTag = getPlayerPositionTag(gameStatusDto.dealerPlayerId);
    //O('dealerPlayerId').innerHTML = resp.dealerPlayerId;
    O('currentDealerId').innerHTML = gameStatusDto.dealerPlayerId;
    // show dealer button

    S(dealerPlayerTag + 'DealerButton').display = 'block';

}

