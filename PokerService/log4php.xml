<configuration xmlns="http://logging.apache.org/log4php/">
    <appender name="serviceAppender" class="LoggerAppenderFile">
        <layout class="LoggerLayoutTTCC" />
        <param name="file" value="/home/cazito5/logs/PokerService.log" />
    </appender>
    <appender name="analyticsAppender" class="LoggerAppenderFile">
        <layout class="LoggerLayoutTTCC" />
        <param name="file" value="/home/cazito5/logs/Analytics.log" />
    </appender>
    <appender name="CasinoTableAppender" class="LoggerAppenderFile">
        <layout class="LoggerLayoutTTCC" />
        <param name="file" value="/home/cazito5/logs/CasinoTable.log" />
    </appender>
    <appender name="ExpectedPokerMoveAppender" class="LoggerAppenderFile">
        <layout class="LoggerLayoutTTCC" />
        <param name="file" value="/home/cazito5/logs/ExpectedPokerMove.log" />
    </appender>
    <appender name="GameCardAppender" class="LoggerAppenderFile">
        <layout class="LoggerLayoutTTCC" />
        <param name="file" value="/home/cazito5/logs/GameCard.log" />
    </appender>
    <appender name="GameInstanceAppender" class="LoggerAppenderFile">
        <layout class="LoggerLayoutTTCC" />
        <param name="file" value="/home/cazito5/logs/GameInstance.log" />
    </appender>
